# Anar Frontend Environment Variables Example
# Copy this file to .env and adjust the URLs to fit your deployment environment.

# Auth Microservice URL
VITE_AUTH_SERVICE_URL=http://localhost:3001

# Goal Microservice URL
VITE_GOAL_SERVICE_URL=http://localhost:3002

# Task Microservice URL
VITE_TASK_SERVICE_URL=http://localhost:3003
